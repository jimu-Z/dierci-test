<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AgriEnvSensorRecordMapper">

    <resultMap type="AgriEnvSensorRecord" id="AgriEnvSensorRecordResult">
        <result property="recordId" column="record_id" />
        <result property="deviceCode" column="device_code" />
        <result property="plotCode" column="plot_code" />
        <result property="temperature" column="temperature" />
        <result property="humidity" column="humidity" />
        <result property="co2Value" column="co2_value" />
        <result property="status" column="status" />
        <result property="dataSource" column="data_source" />
        <result property="collectTime" column="collect_time" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectAgriEnvSensorRecordVo">
        select record_id, device_code, plot_code, temperature, humidity, co2_value, status, data_source,
               collect_time, remark, create_by, create_time, update_by, update_time
        from agri_env_sensor_record
    </sql>

    <select id="selectAgriEnvSensorRecordList" parameterType="AgriEnvSensorRecord" resultMap="AgriEnvSensorRecordResult">
        <include refid="selectAgriEnvSensorRecordVo"/>
        <where>
            <if test="deviceCode != null and deviceCode != ''">
                and device_code like concat('%', #{deviceCode}, '%')
            </if>
            <if test="plotCode != null and plotCode != ''">
                and plot_code like concat('%', #{plotCode}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                and date_format(collect_time, '%y%m%d') &gt;= date_format(#{params.beginTime}, '%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                and date_format(collect_time, '%y%m%d') &lt;= date_format(#{params.endTime}, '%y%m%d')
            </if>
        </where>
        order by collect_time desc, record_id desc
    </select>

    <select id="selectAgriEnvSensorRecordByRecordId" parameterType="Long" resultMap="AgriEnvSensorRecordResult">
        <include refid="selectAgriEnvSensorRecordVo"/>
        where record_id = #{recordId}
    </select>

    <insert id="insertAgriEnvSensorRecord" parameterType="AgriEnvSensorRecord" useGeneratedKeys="true" keyProperty="recordId">
        insert into agri_env_sensor_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="deviceCode != null and deviceCode != ''">device_code,</if>
            <if test="plotCode != null and plotCode != ''">plot_code,</if>
            <if test="temperature != null">temperature,</if>
            <if test="humidity != null">humidity,</if>
            <if test="co2Value != null">co2_value,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="dataSource != null and dataSource != ''">data_source,</if>
            <if test="collectTime != null">collect_time,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="deviceCode != null and deviceCode != ''">#{deviceCode},</if>
            <if test="plotCode != null and plotCode != ''">#{plotCode},</if>
            <if test="temperature != null">#{temperature},</if>
            <if test="humidity != null">#{humidity},</if>
            <if test="co2Value != null">#{co2Value},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="dataSource != null and dataSource != ''">#{dataSource},</if>
            <if test="collectTime != null">#{collectTime},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAgriEnvSensorRecord" parameterType="AgriEnvSensorRecord">
        update agri_env_sensor_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="deviceCode != null and deviceCode != ''">device_code = #{deviceCode},</if>
            <if test="plotCode != null and plotCode != ''">plot_code = #{plotCode},</if>
            <if test="temperature != null">temperature = #{temperature},</if>
            <if test="humidity != null">humidity = #{humidity},</if>
            <if test="co2Value != null">co2_value = #{co2Value},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="dataSource != null and dataSource != ''">data_source = #{dataSource},</if>
            <if test="collectTime != null">collect_time = #{collectTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where record_id = #{recordId}
    </update>

    <delete id="deleteAgriEnvSensorRecordByRecordId" parameterType="Long">
        delete from agri_env_sensor_record where record_id = #{recordId}
    </delete>

    <delete id="deleteAgriEnvSensorRecordByRecordIds" parameterType="Long">
        delete from agri_env_sensor_record where record_id in
        <foreach item="recordId" collection="array" open="(" separator="," close=")">
            #{recordId}
        </foreach>
    </delete>

</mapper>
