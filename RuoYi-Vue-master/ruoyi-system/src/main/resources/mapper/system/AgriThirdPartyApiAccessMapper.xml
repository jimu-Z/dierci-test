<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AgriThirdPartyApiAccessMapper">

    <resultMap type="AgriThirdPartyApiAccess" id="AgriThirdPartyApiAccessResult">
        <result property="accessId" column="access_id" />
        <result property="accessCode" column="access_code" />
        <result property="accessName" column="access_name" />
        <result property="apiType" column="api_type" />
        <result property="provider" column="provider" />
        <result property="endpointUrl" column="endpoint_url" />
        <result property="timeoutSec" column="timeout_sec" />
        <result property="successRate" column="success_rate" />
        <result property="callStatus" column="call_status" />
        <result property="lastCallTime" column="last_call_time" />
        <result property="status" column="status" />
        <result property="remark" column="remark" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectAgriThirdPartyApiAccessVo">
        select access_id, access_code, access_name, api_type, provider, endpoint_url,
               timeout_sec, success_rate, call_status, last_call_time,
               status, remark, create_by, create_time, update_by, update_time
        from agri_third_party_api_access
    </sql>

    <select id="selectAgriThirdPartyApiAccessList" parameterType="AgriThirdPartyApiAccess" resultMap="AgriThirdPartyApiAccessResult">
        <include refid="selectAgriThirdPartyApiAccessVo"/>
        <where>
            <if test="accessCode != null and accessCode != ''">
                and access_code like concat('%', #{accessCode}, '%')
            </if>
            <if test="accessName != null and accessName != ''">
                and access_name like concat('%', #{accessName}, '%')
            </if>
            <if test="apiType != null and apiType != ''">
                and api_type = #{apiType}
            </if>
            <if test="provider != null and provider != ''">
                and provider like concat('%', #{provider}, '%')
            </if>
            <if test="callStatus != null and callStatus != ''">
                and call_status = #{callStatus}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by access_id desc
    </select>

    <select id="selectAgriThirdPartyApiAccessByAccessId" parameterType="Long" resultMap="AgriThirdPartyApiAccessResult">
        <include refid="selectAgriThirdPartyApiAccessVo"/>
        where access_id = #{accessId}
    </select>

    <insert id="insertAgriThirdPartyApiAccess" parameterType="AgriThirdPartyApiAccess" useGeneratedKeys="true" keyProperty="accessId">
        insert into agri_third_party_api_access
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="accessCode != null and accessCode != ''">access_code,</if>
            <if test="accessName != null and accessName != ''">access_name,</if>
            <if test="apiType != null and apiType != ''">api_type,</if>
            <if test="provider != null and provider != ''">provider,</if>
            <if test="endpointUrl != null and endpointUrl != ''">endpoint_url,</if>
            <if test="timeoutSec != null">timeout_sec,</if>
            <if test="successRate != null">success_rate,</if>
            <if test="callStatus != null and callStatus != ''">call_status,</if>
            <if test="lastCallTime != null">last_call_time,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="accessCode != null and accessCode != ''">#{accessCode},</if>
            <if test="accessName != null and accessName != ''">#{accessName},</if>
            <if test="apiType != null and apiType != ''">#{apiType},</if>
            <if test="provider != null and provider != ''">#{provider},</if>
            <if test="endpointUrl != null and endpointUrl != ''">#{endpointUrl},</if>
            <if test="timeoutSec != null">#{timeoutSec},</if>
            <if test="successRate != null">#{successRate},</if>
            <if test="callStatus != null and callStatus != ''">#{callStatus},</if>
            <if test="lastCallTime != null">#{lastCallTime},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAgriThirdPartyApiAccess" parameterType="AgriThirdPartyApiAccess">
        update agri_third_party_api_access
        <trim prefix="SET" suffixOverrides=",">
            <if test="accessCode != null and accessCode != ''">access_code = #{accessCode},</if>
            <if test="accessName != null and accessName != ''">access_name = #{accessName},</if>
            <if test="apiType != null and apiType != ''">api_type = #{apiType},</if>
            <if test="provider != null">provider = #{provider},</if>
            <if test="endpointUrl != null and endpointUrl != ''">endpoint_url = #{endpointUrl},</if>
            <if test="timeoutSec != null">timeout_sec = #{timeoutSec},</if>
            <if test="successRate != null">success_rate = #{successRate},</if>
            <if test="callStatus != null and callStatus != ''">call_status = #{callStatus},</if>
            <if test="lastCallTime != null">last_call_time = #{lastCallTime},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where access_id = #{accessId}
    </update>

    <delete id="deleteAgriThirdPartyApiAccessByAccessId" parameterType="Long">
        delete from agri_third_party_api_access where access_id = #{accessId}
    </delete>

    <delete id="deleteAgriThirdPartyApiAccessByAccessIds" parameterType="Long">
        delete from agri_third_party_api_access where access_id in
        <foreach item="accessId" collection="array" open="(" separator="," close=")">
            #{accessId}
        </foreach>
    </delete>

</mapper>
