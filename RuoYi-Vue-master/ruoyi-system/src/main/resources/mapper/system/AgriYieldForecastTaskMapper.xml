<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AgriYieldForecastTaskMapper">

    <resultMap type="AgriYieldForecastTask" id="AgriYieldForecastTaskResult">
        <result property="forecastId" column="forecast_id" />
        <result property="plotCode" column="plot_code" />
        <result property="cropName" column="crop_name" />
        <result property="season" column="season" />
        <result property="sowDate" column="sow_date" />
        <result property="areaMu" column="area_mu" />
        <result property="forecastYieldKg" column="forecast_yield_kg" />
        <result property="modelVersion" column="model_version" />
        <result property="forecastStatus" column="forecast_status" />
        <result property="forecastTime" column="forecast_time" />
        <result property="status" column="status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectAgriYieldForecastTaskVo">
        select forecast_id, plot_code, crop_name, season, sow_date, area_mu,
               forecast_yield_kg, model_version, forecast_status, forecast_time,
               status, remark, create_by, create_time, update_by, update_time
        from agri_yield_forecast_task
    </sql>

    <select id="selectAgriYieldForecastTaskList" parameterType="AgriYieldForecastTask" resultMap="AgriYieldForecastTaskResult">
        <include refid="selectAgriYieldForecastTaskVo"/>
        <where>
            <if test="plotCode != null and plotCode != ''">
                and plot_code like concat('%', #{plotCode}, '%')
            </if>
            <if test="cropName != null and cropName != ''">
                and crop_name like concat('%', #{cropName}, '%')
            </if>
            <if test="season != null and season != ''">
                and season = #{season}
            </if>
            <if test="forecastStatus != null and forecastStatus != ''">
                and forecast_status = #{forecastStatus}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by forecast_id desc
    </select>

    <select id="selectAgriYieldForecastTaskByForecastId" parameterType="Long" resultMap="AgriYieldForecastTaskResult">
        <include refid="selectAgriYieldForecastTaskVo"/>
        where forecast_id = #{forecastId}
    </select>

    <insert id="insertAgriYieldForecastTask" parameterType="AgriYieldForecastTask" useGeneratedKeys="true" keyProperty="forecastId">
        insert into agri_yield_forecast_task
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="plotCode != null and plotCode != ''">plot_code,</if>
            <if test="cropName != null and cropName != ''">crop_name,</if>
            <if test="season != null and season != ''">season,</if>
            <if test="sowDate != null">sow_date,</if>
            <if test="areaMu != null">area_mu,</if>
            <if test="forecastYieldKg != null">forecast_yield_kg,</if>
            <if test="modelVersion != null and modelVersion != ''">model_version,</if>
            <if test="forecastStatus != null and forecastStatus != ''">forecast_status,</if>
            <if test="forecastTime != null">forecast_time,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="plotCode != null and plotCode != ''">#{plotCode},</if>
            <if test="cropName != null and cropName != ''">#{cropName},</if>
            <if test="season != null and season != ''">#{season},</if>
            <if test="sowDate != null">#{sowDate},</if>
            <if test="areaMu != null">#{areaMu},</if>
            <if test="forecastYieldKg != null">#{forecastYieldKg},</if>
            <if test="modelVersion != null and modelVersion != ''">#{modelVersion},</if>
            <if test="forecastStatus != null and forecastStatus != ''">#{forecastStatus},</if>
            <if test="forecastTime != null">#{forecastTime},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAgriYieldForecastTask" parameterType="AgriYieldForecastTask">
        update agri_yield_forecast_task
        <trim prefix="SET" suffixOverrides=",">
            <if test="plotCode != null and plotCode != ''">plot_code = #{plotCode},</if>
            <if test="cropName != null and cropName != ''">crop_name = #{cropName},</if>
            <if test="season != null and season != ''">season = #{season},</if>
            <if test="sowDate != null">sow_date = #{sowDate},</if>
            <if test="areaMu != null">area_mu = #{areaMu},</if>
            <if test="forecastYieldKg != null">forecast_yield_kg = #{forecastYieldKg},</if>
            <if test="modelVersion != null">model_version = #{modelVersion},</if>
            <if test="forecastStatus != null and forecastStatus != ''">forecast_status = #{forecastStatus},</if>
            <if test="forecastTime != null">forecast_time = #{forecastTime},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where forecast_id = #{forecastId}
    </update>

    <delete id="deleteAgriYieldForecastTaskByForecastId" parameterType="Long">
        delete from agri_yield_forecast_task where forecast_id = #{forecastId}
    </delete>

    <delete id="deleteAgriYieldForecastTaskByForecastIds" parameterType="Long">
        delete from agri_yield_forecast_task where forecast_id in
        <foreach item="forecastId" collection="array" open="(" separator="," close=")">
            #{forecastId}
        </foreach>
    </delete>

</mapper>
