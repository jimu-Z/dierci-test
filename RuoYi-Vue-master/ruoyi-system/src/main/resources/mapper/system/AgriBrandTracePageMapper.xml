<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AgriBrandTracePageMapper">

    <resultMap type="AgriBrandTracePage" id="AgriBrandTracePageResult">
        <result property="pageId" column="page_id" />
        <result property="traceCode" column="trace_code" />
        <result property="brandName" column="brand_name" />
        <result property="productName" column="product_name" />
        <result property="productCode" column="product_code" />
        <result property="originPlace" column="origin_place" />
        <result property="plantingBatchNo" column="planting_batch_no" />
        <result property="processBatchNo" column="process_batch_no" />
        <result property="logisticsTraceCode" column="logistics_trace_code" />
        <result property="coverImageUrl" column="cover_image_url" />
        <result property="pageUrl" column="page_url" />
        <result property="qrCodeUrl" column="qr_code_url" />
        <result property="brandStory" column="brand_story" />
        <result property="publishStatus" column="publish_status" />
        <result property="status" column="status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectAgriBrandTracePageVo">
        select page_id, trace_code, brand_name, product_name, product_code,
               origin_place, planting_batch_no, process_batch_no, logistics_trace_code,
               cover_image_url, page_url, qr_code_url, brand_story, publish_status,
               status, remark, create_by, create_time, update_by, update_time
        from agri_brand_trace_page
    </sql>

    <select id="selectAgriBrandTracePageList" parameterType="AgriBrandTracePage" resultMap="AgriBrandTracePageResult">
        <include refid="selectAgriBrandTracePageVo"/>
        <where>
            <if test="traceCode != null and traceCode != ''">
                and trace_code like concat('%', #{traceCode}, '%')
            </if>
            <if test="brandName != null and brandName != ''">
                and brand_name like concat('%', #{brandName}, '%')
            </if>
            <if test="productName != null and productName != ''">
                and product_name like concat('%', #{productName}, '%')
            </if>
            <if test="publishStatus != null and publishStatus != ''">
                and publish_status = #{publishStatus}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by page_id desc
    </select>

    <select id="selectAgriBrandTracePageByPageId" parameterType="Long" resultMap="AgriBrandTracePageResult">
        <include refid="selectAgriBrandTracePageVo"/>
        where page_id = #{pageId}
    </select>

    <select id="selectAgriBrandTracePageByTraceCode" parameterType="String" resultMap="AgriBrandTracePageResult">
        <include refid="selectAgriBrandTracePageVo"/>
        where trace_code = #{traceCode}
        limit 1
    </select>

    <insert id="insertAgriBrandTracePage" parameterType="AgriBrandTracePage" useGeneratedKeys="true" keyProperty="pageId">
        insert into agri_brand_trace_page
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="traceCode != null and traceCode != ''">trace_code,</if>
            <if test="brandName != null and brandName != ''">brand_name,</if>
            <if test="productName != null and productName != ''">product_name,</if>
            <if test="productCode != null and productCode != ''">product_code,</if>
            <if test="originPlace != null and originPlace != ''">origin_place,</if>
            <if test="plantingBatchNo != null and plantingBatchNo != ''">planting_batch_no,</if>
            <if test="processBatchNo != null and processBatchNo != ''">process_batch_no,</if>
            <if test="logisticsTraceCode != null and logisticsTraceCode != ''">logistics_trace_code,</if>
            <if test="coverImageUrl != null and coverImageUrl != ''">cover_image_url,</if>
            <if test="pageUrl != null and pageUrl != ''">page_url,</if>
            <if test="qrCodeUrl != null and qrCodeUrl != ''">qr_code_url,</if>
            <if test="brandStory != null and brandStory != ''">brand_story,</if>
            <if test="publishStatus != null and publishStatus != ''">publish_status,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="traceCode != null and traceCode != ''">#{traceCode},</if>
            <if test="brandName != null and brandName != ''">#{brandName},</if>
            <if test="productName != null and productName != ''">#{productName},</if>
            <if test="productCode != null and productCode != ''">#{productCode},</if>
            <if test="originPlace != null and originPlace != ''">#{originPlace},</if>
            <if test="plantingBatchNo != null and plantingBatchNo != ''">#{plantingBatchNo},</if>
            <if test="processBatchNo != null and processBatchNo != ''">#{processBatchNo},</if>
            <if test="logisticsTraceCode != null and logisticsTraceCode != ''">#{logisticsTraceCode},</if>
            <if test="coverImageUrl != null and coverImageUrl != ''">#{coverImageUrl},</if>
            <if test="pageUrl != null and pageUrl != ''">#{pageUrl},</if>
            <if test="qrCodeUrl != null and qrCodeUrl != ''">#{qrCodeUrl},</if>
            <if test="brandStory != null and brandStory != ''">#{brandStory},</if>
            <if test="publishStatus != null and publishStatus != ''">#{publishStatus},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAgriBrandTracePage" parameterType="AgriBrandTracePage">
        update agri_brand_trace_page
        <trim prefix="SET" suffixOverrides=",">
            <if test="traceCode != null and traceCode != ''">trace_code = #{traceCode},</if>
            <if test="brandName != null and brandName != ''">brand_name = #{brandName},</if>
            <if test="productName != null and productName != ''">product_name = #{productName},</if>
            <if test="productCode != null and productCode != ''">product_code = #{productCode},</if>
            <if test="originPlace != null">origin_place = #{originPlace},</if>
            <if test="plantingBatchNo != null">planting_batch_no = #{plantingBatchNo},</if>
            <if test="processBatchNo != null">process_batch_no = #{processBatchNo},</if>
            <if test="logisticsTraceCode != null">logistics_trace_code = #{logisticsTraceCode},</if>
            <if test="coverImageUrl != null">cover_image_url = #{coverImageUrl},</if>
            <if test="pageUrl != null">page_url = #{pageUrl},</if>
            <if test="qrCodeUrl != null">qr_code_url = #{qrCodeUrl},</if>
            <if test="brandStory != null">brand_story = #{brandStory},</if>
            <if test="publishStatus != null and publishStatus != ''">publish_status = #{publishStatus},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where page_id = #{pageId}
    </update>

    <delete id="deleteAgriBrandTracePageByPageId" parameterType="Long">
        delete from agri_brand_trace_page where page_id = #{pageId}
    </delete>

    <delete id="deleteAgriBrandTracePageByPageIds" parameterType="Long">
        delete from agri_brand_trace_page where page_id in
        <foreach item="pageId" collection="array" open="(" separator="," close=")">
            #{pageId}
        </foreach>
    </delete>

</mapper>
