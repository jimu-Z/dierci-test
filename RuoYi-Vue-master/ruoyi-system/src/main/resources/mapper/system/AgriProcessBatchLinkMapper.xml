<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AgriProcessBatchLinkMapper">

    <resultMap type="AgriProcessBatchLink" id="AgriProcessBatchLinkResult">
        <result property="linkId" column="link_id" />
        <result property="plantingBatchNo" column="planting_batch_no" />
        <result property="processBatchNo" column="process_batch_no" />
        <result property="productCode" column="product_code" />
        <result property="processWeightKg" column="process_weight_kg" />
        <result property="processStatus" column="process_status" />
        <result property="processTime" column="process_time" />
        <result property="status" column="status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectAgriProcessBatchLinkVo">
        select link_id, planting_batch_no, process_batch_no, product_code,
               process_weight_kg, process_status, process_time, status, remark,
               create_by, create_time, update_by, update_time
        from agri_process_batch_link
    </sql>

    <select id="selectAgriProcessBatchLinkList" parameterType="AgriProcessBatchLink" resultMap="AgriProcessBatchLinkResult">
        <include refid="selectAgriProcessBatchLinkVo"/>
        <where>
            <if test="plantingBatchNo != null and plantingBatchNo != ''">
                and planting_batch_no like concat('%', #{plantingBatchNo}, '%')
            </if>
            <if test="processBatchNo != null and processBatchNo != ''">
                and process_batch_no like concat('%', #{processBatchNo}, '%')
            </if>
            <if test="processStatus != null and processStatus != ''">
                and process_status = #{processStatus}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by link_id desc
    </select>

    <select id="selectAgriProcessBatchLinkByLinkId" parameterType="Long" resultMap="AgriProcessBatchLinkResult">
        <include refid="selectAgriProcessBatchLinkVo"/>
        where link_id = #{linkId}
    </select>

    <insert id="insertAgriProcessBatchLink" parameterType="AgriProcessBatchLink" useGeneratedKeys="true" keyProperty="linkId">
        insert into agri_process_batch_link
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="plantingBatchNo != null and plantingBatchNo != ''">planting_batch_no,</if>
            <if test="processBatchNo != null and processBatchNo != ''">process_batch_no,</if>
            <if test="productCode != null and productCode != ''">product_code,</if>
            <if test="processWeightKg != null">process_weight_kg,</if>
            <if test="processStatus != null and processStatus != ''">process_status,</if>
            <if test="processTime != null">process_time,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="plantingBatchNo != null and plantingBatchNo != ''">#{plantingBatchNo},</if>
            <if test="processBatchNo != null and processBatchNo != ''">#{processBatchNo},</if>
            <if test="productCode != null and productCode != ''">#{productCode},</if>
            <if test="processWeightKg != null">#{processWeightKg},</if>
            <if test="processStatus != null and processStatus != ''">#{processStatus},</if>
            <if test="processTime != null">#{processTime},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAgriProcessBatchLink" parameterType="AgriProcessBatchLink">
        update agri_process_batch_link
        <trim prefix="SET" suffixOverrides=",">
            <if test="plantingBatchNo != null and plantingBatchNo != ''">planting_batch_no = #{plantingBatchNo},</if>
            <if test="processBatchNo != null and processBatchNo != ''">process_batch_no = #{processBatchNo},</if>
            <if test="productCode != null and productCode != ''">product_code = #{productCode},</if>
            <if test="processWeightKg != null">process_weight_kg = #{processWeightKg},</if>
            <if test="processStatus != null and processStatus != ''">process_status = #{processStatus},</if>
            <if test="processTime != null">process_time = #{processTime},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where link_id = #{linkId}
    </update>

    <delete id="deleteAgriProcessBatchLinkByLinkId" parameterType="Long">
        delete from agri_process_batch_link where link_id = #{linkId}
    </delete>

    <delete id="deleteAgriProcessBatchLinkByLinkIds" parameterType="Long">
        delete from agri_process_batch_link where link_id in
        <foreach item="linkId" collection="array" open="(" separator="," close=")">
            #{linkId}
        </foreach>
    </delete>

</mapper>
