<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AgriUserAccessGrantMapper">

    <resultMap type="AgriUserAccessGrant" id="AgriUserAccessGrantResult">
        <result property="grantId" column="grant_id" />
        <result property="userName" column="user_name" />
        <result property="nickName" column="nick_name" />
        <result property="roleKey" column="role_key" />
        <result property="dataScope" column="data_scope" />
        <result property="menuScope" column="menu_scope" />
        <result property="grantStatus" column="grant_status" />
        <result property="status" column="status" />
        <result property="remark" column="remark" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectAgriUserAccessGrantVo">
        select grant_id, user_name, nick_name, role_key, data_scope, menu_scope,
               grant_status, status, remark, create_by, create_time, update_by, update_time
        from agri_user_access_grant
    </sql>

    <select id="selectAgriUserAccessGrantList" parameterType="AgriUserAccessGrant" resultMap="AgriUserAccessGrantResult">
        <include refid="selectAgriUserAccessGrantVo"/>
        <where>
            <if test="userName != null and userName != ''">
                and user_name like concat('%', #{userName}, '%')
            </if>
            <if test="nickName != null and nickName != ''">
                and nick_name like concat('%', #{nickName}, '%')
            </if>
            <if test="roleKey != null and roleKey != ''">
                and role_key = #{roleKey}
            </if>
            <if test="dataScope != null and dataScope != ''">
                and data_scope = #{dataScope}
            </if>
            <if test="grantStatus != null and grantStatus != ''">
                and grant_status = #{grantStatus}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by grant_id desc
    </select>

    <select id="selectAgriUserAccessGrantByGrantId" parameterType="Long" resultMap="AgriUserAccessGrantResult">
        <include refid="selectAgriUserAccessGrantVo"/>
        where grant_id = #{grantId}
    </select>

    <insert id="insertAgriUserAccessGrant" parameterType="AgriUserAccessGrant" useGeneratedKeys="true" keyProperty="grantId">
        insert into agri_user_access_grant
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userName != null and userName != ''">user_name,</if>
            <if test="nickName != null and nickName != ''">nick_name,</if>
            <if test="roleKey != null and roleKey != ''">role_key,</if>
            <if test="dataScope != null and dataScope != ''">data_scope,</if>
            <if test="menuScope != null and menuScope != ''">menu_scope,</if>
            <if test="grantStatus != null and grantStatus != ''">grant_status,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userName != null and userName != ''">#{userName},</if>
            <if test="nickName != null and nickName != ''">#{nickName},</if>
            <if test="roleKey != null and roleKey != ''">#{roleKey},</if>
            <if test="dataScope != null and dataScope != ''">#{dataScope},</if>
            <if test="menuScope != null and menuScope != ''">#{menuScope},</if>
            <if test="grantStatus != null and grantStatus != ''">#{grantStatus},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAgriUserAccessGrant" parameterType="AgriUserAccessGrant">
        update agri_user_access_grant
        <trim prefix="SET" suffixOverrides=",">
            <if test="userName != null and userName != ''">user_name = #{userName},</if>
            <if test="nickName != null">nick_name = #{nickName},</if>
            <if test="roleKey != null and roleKey != ''">role_key = #{roleKey},</if>
            <if test="dataScope != null and dataScope != ''">data_scope = #{dataScope},</if>
            <if test="menuScope != null">menu_scope = #{menuScope},</if>
            <if test="grantStatus != null and grantStatus != ''">grant_status = #{grantStatus},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where grant_id = #{grantId}
    </update>

    <delete id="deleteAgriUserAccessGrantByGrantId" parameterType="Long">
        delete from agri_user_access_grant where grant_id = #{grantId}
    </delete>

    <delete id="deleteAgriUserAccessGrantByGrantIds" parameterType="Long">
        delete from agri_user_access_grant where grant_id in
        <foreach item="grantId" collection="array" open="(" separator="," close=")">
            #{grantId}
        </foreach>
    </delete>

</mapper>
