<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AgriPestIdentifyTaskMapper">

    <resultMap type="AgriPestIdentifyTask" id="AgriPestIdentifyTaskResult">
        <result property="taskId" column="task_id" />
        <result property="plotCode" column="plot_code" />
        <result property="cropName" column="crop_name" />
        <result property="imageUrl" column="image_url" />
        <result property="identifyStatus" column="identify_status" />
        <result property="identifyResult" column="identify_result" />
        <result property="confidence" column="confidence" />
        <result property="identifyTime" column="identify_time" />
        <result property="modelVersion" column="model_version" />
        <result property="status" column="status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectAgriPestIdentifyTaskVo">
        select task_id, plot_code, crop_name, image_url, identify_status, identify_result,
               confidence, identify_time, model_version, status, remark,
               create_by, create_time, update_by, update_time
        from agri_pest_identify_task
    </sql>

    <select id="selectAgriPestIdentifyTaskList" parameterType="AgriPestIdentifyTask" resultMap="AgriPestIdentifyTaskResult">
        <include refid="selectAgriPestIdentifyTaskVo"/>
        <where>
            <if test="plotCode != null and plotCode != ''">
                and plot_code like concat('%', #{plotCode}, '%')
            </if>
            <if test="cropName != null and cropName != ''">
                and crop_name like concat('%', #{cropName}, '%')
            </if>
            <if test="identifyStatus != null and identifyStatus != ''">
                and identify_status = #{identifyStatus}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                and date_format(create_time, '%y%m%d') &gt;= date_format(#{params.beginTime}, '%y%m%d')
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                and date_format(create_time, '%y%m%d') &lt;= date_format(#{params.endTime}, '%y%m%d')
            </if>
        </where>
        order by task_id desc
    </select>

    <select id="selectAgriPestIdentifyTaskByTaskId" parameterType="Long" resultMap="AgriPestIdentifyTaskResult">
        <include refid="selectAgriPestIdentifyTaskVo"/>
        where task_id = #{taskId}
    </select>

    <insert id="insertAgriPestIdentifyTask" parameterType="AgriPestIdentifyTask" useGeneratedKeys="true" keyProperty="taskId">
        insert into agri_pest_identify_task
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="plotCode != null and plotCode != ''">plot_code,</if>
            <if test="cropName != null and cropName != ''">crop_name,</if>
            <if test="imageUrl != null and imageUrl != ''">image_url,</if>
            <if test="identifyStatus != null and identifyStatus != ''">identify_status,</if>
            <if test="identifyResult != null and identifyResult != ''">identify_result,</if>
            <if test="confidence != null">confidence,</if>
            <if test="identifyTime != null">identify_time,</if>
            <if test="modelVersion != null and modelVersion != ''">model_version,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="plotCode != null and plotCode != ''">#{plotCode},</if>
            <if test="cropName != null and cropName != ''">#{cropName},</if>
            <if test="imageUrl != null and imageUrl != ''">#{imageUrl},</if>
            <if test="identifyStatus != null and identifyStatus != ''">#{identifyStatus},</if>
            <if test="identifyResult != null and identifyResult != ''">#{identifyResult},</if>
            <if test="confidence != null">#{confidence},</if>
            <if test="identifyTime != null">#{identifyTime},</if>
            <if test="modelVersion != null and modelVersion != ''">#{modelVersion},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAgriPestIdentifyTask" parameterType="AgriPestIdentifyTask">
        update agri_pest_identify_task
        <trim prefix="SET" suffixOverrides=",">
            <if test="plotCode != null and plotCode != ''">plot_code = #{plotCode},</if>
            <if test="cropName != null and cropName != ''">crop_name = #{cropName},</if>
            <if test="imageUrl != null and imageUrl != ''">image_url = #{imageUrl},</if>
            <if test="identifyStatus != null and identifyStatus != ''">identify_status = #{identifyStatus},</if>
            <if test="identifyResult != null">identify_result = #{identifyResult},</if>
            <if test="confidence != null">confidence = #{confidence},</if>
            <if test="identifyTime != null">identify_time = #{identifyTime},</if>
            <if test="modelVersion != null">model_version = #{modelVersion},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where task_id = #{taskId}
    </update>

    <delete id="deleteAgriPestIdentifyTaskByTaskId" parameterType="Long">
        delete from agri_pest_identify_task where task_id = #{taskId}
    </delete>

    <delete id="deleteAgriPestIdentifyTaskByTaskIds" parameterType="Long">
        delete from agri_pest_identify_task where task_id in
        <foreach item="taskId" collection="array" open="(" separator="," close=")">
            #{taskId}
        </foreach>
    </delete>

</mapper>
