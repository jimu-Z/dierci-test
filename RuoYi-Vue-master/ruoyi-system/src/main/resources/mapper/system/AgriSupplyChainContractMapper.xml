<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AgriSupplyChainContractMapper">

    <resultMap type="AgriSupplyChainContract" id="AgriSupplyChainContractResult">
        <result property="contractId" column="contract_id" />
        <result property="contractNo" column="contract_no" />
        <result property="contractName" column="contract_name" />
        <result property="financeSubject" column="finance_subject" />
        <result property="financeAmount" column="finance_amount" />
        <result property="interestRate" column="interest_rate" />
        <result property="startDate" column="start_date" />
        <result property="endDate" column="end_date" />
        <result property="contractStatus" column="contract_status" />
        <result property="riskLevel" column="risk_level" />
        <result property="status" column="status" />
        <result property="remark" column="remark" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectAgriSupplyChainContractVo">
        select contract_id, contract_no, contract_name, finance_subject, finance_amount,
               interest_rate, start_date, end_date, contract_status, risk_level,
               status, remark, create_by, create_time, update_by, update_time
        from agri_supply_chain_contract
    </sql>

    <select id="selectAgriSupplyChainContractList" parameterType="AgriSupplyChainContract" resultMap="AgriSupplyChainContractResult">
        <include refid="selectAgriSupplyChainContractVo"/>
        <where>
            <if test="contractNo != null and contractNo != ''">
                and contract_no like concat('%', #{contractNo}, '%')
            </if>
            <if test="contractName != null and contractName != ''">
                and contract_name like concat('%', #{contractName}, '%')
            </if>
            <if test="financeSubject != null and financeSubject != ''">
                and finance_subject like concat('%', #{financeSubject}, '%')
            </if>
            <if test="contractStatus != null and contractStatus != ''">
                and contract_status = #{contractStatus}
            </if>
            <if test="riskLevel != null and riskLevel != ''">
                and risk_level = #{riskLevel}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by contract_id desc
    </select>

    <select id="selectAgriSupplyChainContractByContractId" parameterType="Long" resultMap="AgriSupplyChainContractResult">
        <include refid="selectAgriSupplyChainContractVo"/>
        where contract_id = #{contractId}
    </select>

    <insert id="insertAgriSupplyChainContract" parameterType="AgriSupplyChainContract" useGeneratedKeys="true" keyProperty="contractId">
        insert into agri_supply_chain_contract
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="contractNo != null and contractNo != ''">contract_no,</if>
            <if test="contractName != null and contractName != ''">contract_name,</if>
            <if test="financeSubject != null and financeSubject != ''">finance_subject,</if>
            <if test="financeAmount != null">finance_amount,</if>
            <if test="interestRate != null">interest_rate,</if>
            <if test="startDate != null">start_date,</if>
            <if test="endDate != null">end_date,</if>
            <if test="contractStatus != null and contractStatus != ''">contract_status,</if>
            <if test="riskLevel != null and riskLevel != ''">risk_level,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="contractNo != null and contractNo != ''">#{contractNo},</if>
            <if test="contractName != null and contractName != ''">#{contractName},</if>
            <if test="financeSubject != null and financeSubject != ''">#{financeSubject},</if>
            <if test="financeAmount != null">#{financeAmount},</if>
            <if test="interestRate != null">#{interestRate},</if>
            <if test="startDate != null">#{startDate},</if>
            <if test="endDate != null">#{endDate},</if>
            <if test="contractStatus != null and contractStatus != ''">#{contractStatus},</if>
            <if test="riskLevel != null and riskLevel != ''">#{riskLevel},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAgriSupplyChainContract" parameterType="AgriSupplyChainContract">
        update agri_supply_chain_contract
        <trim prefix="SET" suffixOverrides=",">
            <if test="contractNo != null and contractNo != ''">contract_no = #{contractNo},</if>
            <if test="contractName != null and contractName != ''">contract_name = #{contractName},</if>
            <if test="financeSubject != null and financeSubject != ''">finance_subject = #{financeSubject},</if>
            <if test="financeAmount != null">finance_amount = #{financeAmount},</if>
            <if test="interestRate != null">interest_rate = #{interestRate},</if>
            <if test="startDate != null">start_date = #{startDate},</if>
            <if test="endDate != null">end_date = #{endDate},</if>
            <if test="contractStatus != null and contractStatus != ''">contract_status = #{contractStatus},</if>
            <if test="riskLevel != null and riskLevel != ''">risk_level = #{riskLevel},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where contract_id = #{contractId}
    </update>

    <delete id="deleteAgriSupplyChainContractByContractId" parameterType="Long">
        delete from agri_supply_chain_contract where contract_id = #{contractId}
    </delete>

    <delete id="deleteAgriSupplyChainContractByContractIds" parameterType="Long">
        delete from agri_supply_chain_contract where contract_id in
        <foreach item="contractId" collection="array" open="(" separator="," close=")">
            #{contractId}
        </foreach>
    </delete>

</mapper>
