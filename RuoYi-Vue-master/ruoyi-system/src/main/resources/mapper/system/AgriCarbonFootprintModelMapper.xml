<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AgriCarbonFootprintModelMapper">

    <resultMap type="AgriCarbonFootprintModel" id="AgriCarbonFootprintModelResult">
        <result property="modelId" column="model_id" />
        <result property="modelCode" column="model_code" />
        <result property="modelName" column="model_name" />
        <result property="productType" column="product_type" />
        <result property="boundaryScope" column="boundary_scope" />
        <result property="emissionFactor" column="emission_factor" />
        <result property="carbonEmission" column="carbon_emission" />
        <result property="calcStatus" column="calc_status" />
        <result property="calcTime" column="calc_time" />
        <result property="verifier" column="verifier" />
        <result property="status" column="status" />
        <result property="remark" column="remark" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectAgriCarbonFootprintModelVo">
        select model_id, model_code, model_name, product_type, boundary_scope,
               emission_factor, carbon_emission, calc_status, calc_time, verifier,
               status, remark, create_by, create_time, update_by, update_time
        from agri_carbon_footprint_model
    </sql>

    <select id="selectAgriCarbonFootprintModelList" parameterType="AgriCarbonFootprintModel" resultMap="AgriCarbonFootprintModelResult">
        <include refid="selectAgriCarbonFootprintModelVo"/>
        <where>
            <if test="modelCode != null and modelCode != ''">
                and model_code like concat('%', #{modelCode}, '%')
            </if>
            <if test="modelName != null and modelName != ''">
                and model_name like concat('%', #{modelName}, '%')
            </if>
            <if test="productType != null and productType != ''">
                and product_type = #{productType}
            </if>
            <if test="calcStatus != null and calcStatus != ''">
                and calc_status = #{calcStatus}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by model_id desc
    </select>

    <select id="selectAgriCarbonFootprintModelByModelId" parameterType="Long" resultMap="AgriCarbonFootprintModelResult">
        <include refid="selectAgriCarbonFootprintModelVo"/>
        where model_id = #{modelId}
    </select>

    <insert id="insertAgriCarbonFootprintModel" parameterType="AgriCarbonFootprintModel" useGeneratedKeys="true" keyProperty="modelId">
        insert into agri_carbon_footprint_model
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="modelCode != null and modelCode != ''">model_code,</if>
            <if test="modelName != null and modelName != ''">model_name,</if>
            <if test="productType != null and productType != ''">product_type,</if>
            <if test="boundaryScope != null and boundaryScope != ''">boundary_scope,</if>
            <if test="emissionFactor != null">emission_factor,</if>
            <if test="carbonEmission != null">carbon_emission,</if>
            <if test="calcStatus != null and calcStatus != ''">calc_status,</if>
            <if test="calcTime != null">calc_time,</if>
            <if test="verifier != null and verifier != ''">verifier,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="modelCode != null and modelCode != ''">#{modelCode},</if>
            <if test="modelName != null and modelName != ''">#{modelName},</if>
            <if test="productType != null and productType != ''">#{productType},</if>
            <if test="boundaryScope != null and boundaryScope != ''">#{boundaryScope},</if>
            <if test="emissionFactor != null">#{emissionFactor},</if>
            <if test="carbonEmission != null">#{carbonEmission},</if>
            <if test="calcStatus != null and calcStatus != ''">#{calcStatus},</if>
            <if test="calcTime != null">#{calcTime},</if>
            <if test="verifier != null and verifier != ''">#{verifier},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAgriCarbonFootprintModel" parameterType="AgriCarbonFootprintModel">
        update agri_carbon_footprint_model
        <trim prefix="SET" suffixOverrides=",">
            <if test="modelCode != null and modelCode != ''">model_code = #{modelCode},</if>
            <if test="modelName != null and modelName != ''">model_name = #{modelName},</if>
            <if test="productType != null and productType != ''">product_type = #{productType},</if>
            <if test="boundaryScope != null">boundary_scope = #{boundaryScope},</if>
            <if test="emissionFactor != null">emission_factor = #{emissionFactor},</if>
            <if test="carbonEmission != null">carbon_emission = #{carbonEmission},</if>
            <if test="calcStatus != null and calcStatus != ''">calc_status = #{calcStatus},</if>
            <if test="calcTime != null">calc_time = #{calcTime},</if>
            <if test="verifier != null">verifier = #{verifier},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where model_id = #{modelId}
    </update>

    <delete id="deleteAgriCarbonFootprintModelByModelId" parameterType="Long">
        delete from agri_carbon_footprint_model where model_id = #{modelId}
    </delete>

    <delete id="deleteAgriCarbonFootprintModelByModelIds" parameterType="Long">
        delete from agri_carbon_footprint_model where model_id in
        <foreach item="modelId" collection="array" open="(" separator="," close=")">
            #{modelId}
        </foreach>
    </delete>

</mapper>
