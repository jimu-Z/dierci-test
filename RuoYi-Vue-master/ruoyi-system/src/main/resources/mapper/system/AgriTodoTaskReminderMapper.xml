<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AgriTodoTaskReminderMapper">

    <resultMap type="AgriTodoTaskReminder" id="AgriTodoTaskReminderResult">
        <result property="reminderId" column="reminder_id" />
        <result property="taskCode" column="task_code" />
        <result property="taskTitle" column="task_title" />
        <result property="taskType" column="task_type" />
        <result property="priorityLevel" column="priority_level" />
        <result property="assignee" column="assignee" />
        <result property="deadlineTime" column="deadline_time" />
        <result property="reminderStatus" column="reminder_status" />
        <result property="status" column="status" />
        <result property="remark" column="remark" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectAgriTodoTaskReminderVo">
        select reminder_id, task_code, task_title, task_type, priority_level,
               assignee, deadline_time, reminder_status, status, remark,
               create_by, create_time, update_by, update_time
        from agri_todo_task_reminder
    </sql>

    <select id="selectAgriTodoTaskReminderList" parameterType="AgriTodoTaskReminder" resultMap="AgriTodoTaskReminderResult">
        <include refid="selectAgriTodoTaskReminderVo"/>
        <where>
            <if test="taskCode != null and taskCode != ''">
                and task_code like concat('%', #{taskCode}, '%')
            </if>
            <if test="taskTitle != null and taskTitle != ''">
                and task_title like concat('%', #{taskTitle}, '%')
            </if>
            <if test="priorityLevel != null and priorityLevel != ''">
                and priority_level = #{priorityLevel}
            </if>
            <if test="assignee != null and assignee != ''">
                and assignee like concat('%', #{assignee}, '%')
            </if>
            <if test="reminderStatus != null and reminderStatus != ''">
                and reminder_status = #{reminderStatus}
            </if>
        </where>
        order by deadline_time asc, reminder_id desc
    </select>

    <select id="selectAgriTodoTaskReminderByReminderId" parameterType="Long" resultMap="AgriTodoTaskReminderResult">
        <include refid="selectAgriTodoTaskReminderVo"/>
        where reminder_id = #{reminderId}
    </select>

    <insert id="insertAgriTodoTaskReminder" parameterType="AgriTodoTaskReminder" useGeneratedKeys="true" keyProperty="reminderId">
        insert into agri_todo_task_reminder
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="taskCode != null and taskCode != ''">task_code,</if>
            <if test="taskTitle != null and taskTitle != ''">task_title,</if>
            <if test="taskType != null and taskType != ''">task_type,</if>
            <if test="priorityLevel != null and priorityLevel != ''">priority_level,</if>
            <if test="assignee != null and assignee != ''">assignee,</if>
            <if test="deadlineTime != null">deadline_time,</if>
            <if test="reminderStatus != null and reminderStatus != ''">reminder_status,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="taskCode != null and taskCode != ''">#{taskCode},</if>
            <if test="taskTitle != null and taskTitle != ''">#{taskTitle},</if>
            <if test="taskType != null and taskType != ''">#{taskType},</if>
            <if test="priorityLevel != null and priorityLevel != ''">#{priorityLevel},</if>
            <if test="assignee != null and assignee != ''">#{assignee},</if>
            <if test="deadlineTime != null">#{deadlineTime},</if>
            <if test="reminderStatus != null and reminderStatus != ''">#{reminderStatus},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAgriTodoTaskReminder" parameterType="AgriTodoTaskReminder">
        update agri_todo_task_reminder
        <trim prefix="SET" suffixOverrides=",">
            <if test="taskCode != null and taskCode != ''">task_code = #{taskCode},</if>
            <if test="taskTitle != null and taskTitle != ''">task_title = #{taskTitle},</if>
            <if test="taskType != null">task_type = #{taskType},</if>
            <if test="priorityLevel != null and priorityLevel != ''">priority_level = #{priorityLevel},</if>
            <if test="assignee != null and assignee != ''">assignee = #{assignee},</if>
            <if test="deadlineTime != null">deadline_time = #{deadlineTime},</if>
            <if test="reminderStatus != null and reminderStatus != ''">reminder_status = #{reminderStatus},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where reminder_id = #{reminderId}
    </update>

    <delete id="deleteAgriTodoTaskReminderByReminderId" parameterType="Long">
        delete from agri_todo_task_reminder where reminder_id = #{reminderId}
    </delete>

    <delete id="deleteAgriTodoTaskReminderByReminderIds" parameterType="Long">
        delete from agri_todo_task_reminder where reminder_id in
        <foreach item="reminderId" collection="array" open="(" separator="," close=")">
            #{reminderId}
        </foreach>
    </delete>

</mapper>
