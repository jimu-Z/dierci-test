<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AgriMarketForecastMapper">

    <resultMap type="AgriMarketForecast" id="AgriMarketForecastResult">
        <result property="forecastId" column="forecast_id" />
        <result property="marketArea" column="market_area" />
        <result property="productCode" column="product_code" />
        <result property="productName" column="product_name" />
        <result property="periodStart" column="period_start" />
        <result property="periodEnd" column="period_end" />
        <result property="historicalSalesKg" column="historical_sales_kg" />
        <result property="forecastSalesKg" column="forecast_sales_kg" />
        <result property="forecastPrice" column="forecast_price" />
        <result property="confidenceRate" column="confidence_rate" />
        <result property="modelVersion" column="model_version" />
        <result property="forecastStatus" column="forecast_status" />
        <result property="forecastTime" column="forecast_time" />
        <result property="status" column="status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
    </resultMap>

    <sql id="selectAgriMarketForecastVo">
        select forecast_id, market_area, product_code, product_name, period_start, period_end,
               historical_sales_kg, forecast_sales_kg, forecast_price, confidence_rate,
               model_version, forecast_status, forecast_time, status, remark,
               create_by, create_time, update_by, update_time
        from agri_market_forecast
    </sql>

    <select id="selectAgriMarketForecastList" parameterType="AgriMarketForecast" resultMap="AgriMarketForecastResult">
        <include refid="selectAgriMarketForecastVo"/>
        <where>
            <if test="marketArea != null and marketArea != ''">
                and market_area like concat('%', #{marketArea}, '%')
            </if>
            <if test="productCode != null and productCode != ''">
                and product_code like concat('%', #{productCode}, '%')
            </if>
            <if test="productName != null and productName != ''">
                and product_name like concat('%', #{productName}, '%')
            </if>
            <if test="forecastStatus != null and forecastStatus != ''">
                and forecast_status = #{forecastStatus}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by forecast_id desc
    </select>

    <select id="selectAgriMarketForecastByForecastId" parameterType="Long" resultMap="AgriMarketForecastResult">
        <include refid="selectAgriMarketForecastVo"/>
        where forecast_id = #{forecastId}
    </select>

    <insert id="insertAgriMarketForecast" parameterType="AgriMarketForecast" useGeneratedKeys="true" keyProperty="forecastId">
        insert into agri_market_forecast
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="marketArea != null and marketArea != ''">market_area,</if>
            <if test="productCode != null and productCode != ''">product_code,</if>
            <if test="productName != null and productName != ''">product_name,</if>
            <if test="periodStart != null">period_start,</if>
            <if test="periodEnd != null">period_end,</if>
            <if test="historicalSalesKg != null">historical_sales_kg,</if>
            <if test="forecastSalesKg != null">forecast_sales_kg,</if>
            <if test="forecastPrice != null">forecast_price,</if>
            <if test="confidenceRate != null">confidence_rate,</if>
            <if test="modelVersion != null and modelVersion != ''">model_version,</if>
            <if test="forecastStatus != null and forecastStatus != ''">forecast_status,</if>
            <if test="forecastTime != null">forecast_time,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="marketArea != null and marketArea != ''">#{marketArea},</if>
            <if test="productCode != null and productCode != ''">#{productCode},</if>
            <if test="productName != null and productName != ''">#{productName},</if>
            <if test="periodStart != null">#{periodStart},</if>
            <if test="periodEnd != null">#{periodEnd},</if>
            <if test="historicalSalesKg != null">#{historicalSalesKg},</if>
            <if test="forecastSalesKg != null">#{forecastSalesKg},</if>
            <if test="forecastPrice != null">#{forecastPrice},</if>
            <if test="confidenceRate != null">#{confidenceRate},</if>
            <if test="modelVersion != null and modelVersion != ''">#{modelVersion},</if>
            <if test="forecastStatus != null and forecastStatus != ''">#{forecastStatus},</if>
            <if test="forecastTime != null">#{forecastTime},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateAgriMarketForecast" parameterType="AgriMarketForecast">
        update agri_market_forecast
        <trim prefix="SET" suffixOverrides=",">
            <if test="marketArea != null and marketArea != ''">market_area = #{marketArea},</if>
            <if test="productCode != null and productCode != ''">product_code = #{productCode},</if>
            <if test="productName != null and productName != ''">product_name = #{productName},</if>
            <if test="periodStart != null">period_start = #{periodStart},</if>
            <if test="periodEnd != null">period_end = #{periodEnd},</if>
            <if test="historicalSalesKg != null">historical_sales_kg = #{historicalSalesKg},</if>
            <if test="forecastSalesKg != null">forecast_sales_kg = #{forecastSalesKg},</if>
            <if test="forecastPrice != null">forecast_price = #{forecastPrice},</if>
            <if test="confidenceRate != null">confidence_rate = #{confidenceRate},</if>
            <if test="modelVersion != null">model_version = #{modelVersion},</if>
            <if test="forecastStatus != null and forecastStatus != ''">forecast_status = #{forecastStatus},</if>
            <if test="forecastTime != null">forecast_time = #{forecastTime},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </trim>
        where forecast_id = #{forecastId}
    </update>

    <delete id="deleteAgriMarketForecastByForecastId" parameterType="Long">
        delete from agri_market_forecast where forecast_id = #{forecastId}
    </delete>

    <delete id="deleteAgriMarketForecastByForecastIds" parameterType="Long">
        delete from agri_market_forecast where forecast_id in
        <foreach item="forecastId" collection="array" open="(" separator="," close=")">
            #{forecastId}
        </foreach>
    </delete>

</mapper>
